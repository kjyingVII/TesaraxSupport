NODE_ENV=production

POSTGRES_DB=support_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-strong-db-password

WEB_APP_URL=https://support.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
CORS_ORIGINS=https://support.yourdomain.com

JWT_ACCESS_SECRET=change-this-long-random-access-secret
JWT_REFRESH_SECRET=change-this-long-random-refresh-secret

WEB_PORT=13000
API_PORT=14000
POSTGRES_PORT=5432
REDIS_PORT=6379

WEB_BIND=127.0.0.1
API_BIND=127.0.0.1
POSTGRES_BIND=127.0.0.1
REDIS_BIND=127.0.0.1

# WhatsApp notification provider.
# Keep "log" to record notification attempts without sending messages.
# Use "meta" for Meta WhatsApp Cloud API.
# Use "twilio" for Twilio WhatsApp while Meta app review is pending.
WHATSAPP_PROVIDER=log
WHATSAPP_META_GRAPH_API_VERSION=v20.0
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_WEBHOOK_VERIFY_TOKEN=change-this-webhook-verify-token
WHATSAPP_META_APP_SECRET=
WHATSAPP_META_MESSAGE_MODE=text
WHATSAPP_META_TEMPLATE_LANGUAGE=en
WHATSAPP_META_TEMPLATE_TICKET_CREATED_REQUESTER=new_ticket_notification
WHATSAPP_META_TEMPLATE_TICKET_CREATED_TECHNICIAN=new_ticket_notification
WHATSAPP_META_TEMPLATE_TICKET_STATUS_CHANGED=ticket_status_change_notification
WHATSAPP_META_TEMPLATE_SERVICE_REPORT_SUBMITTED=service_report_submitted_notification
WHATSAPP_META_TEMPLATE_MACHINE_LOG_CREATED=
WHATSAPP_META_TEMPLATE_SCHEDULED_TASK_CREATED=scheduled_task_created_notification
WHATSAPP_META_TEMPLATE_SCHEDULED_TASK_RESCHEDULED=scheduled_task_rescheduled_notification
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_STATUS_CALLBACK_URL=https://api.yourdomain.com/api/webhooks/twilio/whatsapp/status
TWILIO_MESSAGE_MODE=body
TWILIO_CONTENT_SID_TICKET_CREATED_REQUESTER=
TWILIO_CONTENT_SID_TICKET_CREATED_TECHNICIAN=
TWILIO_CONTENT_SID_TICKET_STATUS_CHANGED=
TWILIO_CONTENT_SID_SERVICE_REPORT_SUBMITTED=
TWILIO_CONTENT_SID_SCHEDULED_TASK_CREATED=
TWILIO_CONTENT_SID_SCHEDULED_TASK_RESCHEDULED=
