generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  TECHNICIAN
}

enum TicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_PARTS
  WAITING_FOR_REQUESTER
  RESOLVED
  PENDING_ACKNOWLEDGEMENT
  CLOSED
  FOLLOW_UP_REQUIRED
  CANCELLED
}

enum TicketPriority {
  LOW
  NORMAL
  URGENT
  MACHINE_DOWN
}

enum MachineActivityType {
  CORRECTIVE_SERVICE
  MACHINE_MAINTENANCE
  COMPONENT_REPLACEMENT
  INSPECTION_DIAGNOSIS
  UPGRADE
  OTHER
}

enum ReminderType {
  UPCOMING
  DUE
  OVERDUE
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum AcknowledgementResponse {
  ACCEPTED
  FOLLOW_UP_REQUESTED
}

enum TicketCommentVisibility {
  INTERNAL
  REQUESTER_VISIBLE
}

enum ServiceResolutionStatus {
  RESOLVED
  PARTIALLY_RESOLVED
  NOT_RESOLVED
}

enum TaskStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  WAITING_COMPONENT
  WAITING_CUSTOMER
  COMPLETED
  CANCELLED
}

enum TaskType {
  CORRECTIVE_SERVICE
  MACHINE_MAINTENANCE
  COMPONENT_REPLACEMENT
  INSPECTION_DIAGNOSIS
  UPGRADE
  FOLLOW_UP_VISIT
  OTHER
}

enum AttachmentRelatedType {
  TICKET
  TICKET_COMMENT
  SERVICE_REPORT
  MACHINE_LOG
  MACHINE_DOCUMENT
  MACHINE_SUPPORT_LOGO
  ACKNOWLEDGEMENT_SIGNATURE
}

model User {
  id                  String                @id @default(uuid())
  name                String
  email               String                @unique
  phone               String?
  passwordHash        String
  role                UserRole
  isActive            Boolean               @default(true)
  lastLoginAt         DateTime?
  assignedTickets     Ticket[]              @relation("AssignedTechnician")
  serviceReports      ServiceReport[]
  machineLogs         MachineLog[]          @relation("MachineLogUser")
  statusChanges       TicketStatusHistory[] @relation("StatusChangedBy")
  comments            TicketComment[]
  assignmentsMade     TicketAssignment[]    @relation("AssignedBy")
  assignmentsReceived TicketAssignment[]    @relation("AssignedTo")
  assignmentsUnassigned TicketAssignment[]  @relation("UnassignedBy")
  customerAssignments CustomerTechnicianAssignment[] @relation("CustomerTechnician")
  customerAssignmentsAssigned CustomerTechnicianAssignment[] @relation("CustomerTechnicianAssignedBy")
  machineAssignments  MachineTechnicianAssignment[]  @relation("MachineTechnician")
  machineAssignmentsAssigned MachineTechnicianAssignment[] @relation("MachineTechnicianAssignedBy")
  tasksCreated Task[] @relation("TaskCreatedBy")
  tasksCompleted Task[] @relation("TaskCompletedBy")
  taskAssignments TaskAssignment[] @relation("TaskTechnician")
  taskAssignmentsMade TaskAssignment[] @relation("TaskAssignedBy")
  taskComments TaskComment[]
  attachments         Attachment[]
  auditLogs           AuditLog[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([role, isActive, createdAt], map: "User_role_isActive_createdAt_idx")
}

model Customer {
  id           String    @id @default(uuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  remarks      String?
  isActive     Boolean   @default(true)
  machines     Machine[]
  technicianAssignments CustomerTechnicianAssignment[]
  tasks Task[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([name])
  @@index([isActive])
  @@index([isActive, createdAt], map: "Customer_isActive_createdAt_idx")
}

model Machine {
  id                          String               @id @default(uuid())
  publicId                    String               @unique
  customerId                  String
  customer                    Customer             @relation(fields: [customerId], references: [id])
  machineName                 String
  model                       String
  serialNumber                String
  location                    String
  supportCompanyName          String?
  supportCompanyLogoAttachmentId String?   @unique
  supportCompanyLogoAttachment Attachment? @relation("MachineSupportCompanyLogo", fields: [supportCompanyLogoAttachmentId], references: [id])
  qrCodeUrl                   String?
  machineAccessPasswordHash   String?
  machineAccessPasswordUpdatedAt DateTime?
  serviceReminderIntervalDays Int
  lastServiceAt               DateTime?
  nextServiceDueAt            DateTime?
  installationDate            DateTime?
  warrantyExpiryDate          DateTime?
  internalRemarks             String?
  isActive                    Boolean              @default(true)
  tickets                     Ticket[]
  logs                        MachineLog[]
  documents                   Attachment[]           @relation("MachineAttachments")
  serviceReminderLogs         ServiceReminderLog[]
  technicianAssignments       MachineTechnicianAssignment[]
  tasks                       Task[]
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  @@index([customerId])
  @@index([serialNumber])
  @@index([nextServiceDueAt])
  @@index([isActive])
  @@index([customerId, createdAt], map: "Machine_customerId_createdAt_idx")
  @@index([isActive, createdAt], map: "Machine_isActive_createdAt_idx")
  @@index([isActive, nextServiceDueAt], map: "Machine_isActive_nextServiceDueAt_idx")
}

model Ticket {
  id                   String                @id @default(uuid())
  ticketNumber         String                @unique
  machineId            String
  machine              Machine               @relation(fields: [machineId], references: [id])
  requesterName        String
  requesterCompany     String?
  requesterDepartment  String?
  requesterPhone       String?
  requesterEmail       String?
  issueTitle           String
  issueDescription     String
  issueCategory        String
  priority             TicketPriority
  status               TicketStatus          @default(NEW)
  assignedTechnicianId String?
  assignedTechnician   User?                 @relation("AssignedTechnician", fields: [assignedTechnicianId], references: [id])
  createdFromPublicQr  Boolean               @default(false)
  statusHistory        TicketStatusHistory[]
  comments             TicketComment[]
  assignments          TicketAssignment[]
  serviceReports       ServiceReport[]
  acknowledgements     Acknowledgement[]
  attachments          Attachment[]
  machineLogs          MachineLog[]
  tasks                Task[]
  closedAt             DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([machineId])
  @@index([status])
  @@index([priority])
  @@index([assignedTechnicianId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, createdAt], map: "Ticket_status_createdAt_idx")
  @@index([machineId, createdAt], map: "Ticket_machineId_createdAt_idx")
  @@index([assignedTechnicianId, createdAt], map: "Ticket_assignedTechnicianId_createdAt_idx")
  @@index([priority, createdAt], map: "Ticket_priority_createdAt_idx")
}

model TicketStatusHistory {
  id                     String        @id @default(uuid())
  ticketId               String
  ticket                 Ticket        @relation(fields: [ticketId], references: [id])
  fromStatus             TicketStatus?
  toStatus               TicketStatus
  changedByUserId        String?
  changedByUser          User?         @relation("StatusChangedBy", fields: [changedByUserId], references: [id])
  changedByRequesterName String?
  comment                String?
  createdAt              DateTime      @default(now())

  @@index([ticketId])
  @@index([changedByUserId])
  @@index([createdAt])
  @@index([ticketId, createdAt], map: "TicketStatusHistory_ticketId_createdAt_idx")
}

model TicketComment {
  id                     String                  @id @default(uuid())
  ticketId               String
  ticket                 Ticket                  @relation(fields: [ticketId], references: [id])
  comment                String
  visibility             TicketCommentVisibility @default(INTERNAL)
  createdByUserId        String?
  createdByUser          User?                   @relation(fields: [createdByUserId], references: [id])
  createdByRequesterName String?
  attachments            Attachment[]
  createdAt              DateTime                @default(now())

  @@index([ticketId])
  @@index([createdByUserId])
  @@index([ticketId, createdAt], map: "TicketComment_ticketId_createdAt_idx")
  @@index([ticketId, visibility, createdAt], map: "TicketComment_ticketId_visibility_createdAt_idx")
}

model TicketAssignment {
  id               String   @id @default(uuid())
  ticketId         String
  ticket           Ticket   @relation(fields: [ticketId], references: [id])
  assignedToUserId String
  assignedToUser   User     @relation("AssignedTo", fields: [assignedToUserId], references: [id])
  assignedByUserId String
  assignedByUser   User     @relation("AssignedBy", fields: [assignedByUserId], references: [id])
  unassignedByUserId String?
  unassignedByUser   User?    @relation("UnassignedBy", fields: [unassignedByUserId], references: [id])
  isActive         Boolean  @default(true)
  isLead           Boolean  @default(false)
  comment          String?
  unassignedAt     DateTime?
  createdAt        DateTime @default(now())

  @@index([ticketId])
  @@index([assignedToUserId])
  @@index([assignedByUserId])
  @@index([unassignedByUserId])
  @@index([isActive])
  @@index([isLead])
  @@index([ticketId, isActive], map: "TicketAssignment_ticketId_isActive_idx")
  @@index([assignedToUserId, isActive], map: "TicketAssignment_assignedToUserId_isActive_idx")
  @@index([isActive, isLead], map: "TicketAssignment_isActive_isLead_idx")
}

model CustomerTechnicianAssignment {
  id             String   @id @default(uuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id])
  technicianId   String
  technician     User     @relation("CustomerTechnician", fields: [technicianId], references: [id])
  assignedByUserId String?
  assignedByUser User?    @relation("CustomerTechnicianAssignedBy", fields: [assignedByUserId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([customerId, technicianId])
  @@index([customerId])
  @@index([technicianId])
  @@index([assignedByUserId])
}

model MachineTechnicianAssignment {
  id             String   @id @default(uuid())
  machineId      String
  machine        Machine  @relation(fields: [machineId], references: [id])
  technicianId   String
  technician     User     @relation("MachineTechnician", fields: [technicianId], references: [id])
  assignedByUserId String?
  assignedByUser User?    @relation("MachineTechnicianAssignedBy", fields: [assignedByUserId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([machineId, technicianId])
  @@index([machineId])
  @@index([technicianId])
  @@index([assignedByUserId])
}

model ServiceReport {
  id                             String                  @id @default(uuid())
  ticketId                       String
  ticket                         Ticket                  @relation(fields: [ticketId], references: [id])
  technicianId                   String
  technician                     User                    @relation(fields: [technicianId], references: [id])
  diagnosis                      String
  actionTaken                    String
  partsUsed                      String?
  recommendations                String?
  technicianRemarks              String?
  serviceStartAt                 DateTime
  serviceEndAt                   DateTime
  resolutionStatus               ServiceResolutionStatus
  submittedForAcknowledgementAt  DateTime?
  acknowledgement                Acknowledgement?
  attachments                    Attachment[]
  machineLogs                    MachineLog[]
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt

  @@index([ticketId])
  @@index([technicianId])
  @@index([ticketId, createdAt], map: "ServiceReport_ticketId_createdAt_idx")
  @@index([technicianId, createdAt], map: "ServiceReport_technicianId_createdAt_idx")
}

model MachineLog {
  id                         String         @id @default(uuid())
  machineId                  String
  machine                    Machine        @relation(fields: [machineId], references: [id])
  ticketId                   String?
  ticket                     Ticket?        @relation(fields: [ticketId], references: [id])
  serviceReportId            String?
  serviceReport              ServiceReport? @relation(fields: [serviceReportId], references: [id])
  activityType               MachineActivityType
  workDate                   DateTime
  workEndAt                  DateTime?
  title                      String
  workSummary                String
  partsUsed                  String?
  upgradeVersion             String?
  upgradeDescription         String?
  nextServiceDueOverrideAt   DateTime?
  requesterConfirmedName     String?
  requesterContactPhone      String?
  requesterContactEmail      String?
  requesterAcknowledgementRequired Boolean      @default(false)
  requesterConfirmedAt       DateTime?
  notifyCustomer             Boolean       @default(false)
  notifyRecipientName        String?
  notifyRecipientPhone       String?
  notifyRecipientEmail       String?
  notifyMessage              String?
  notifiedAt                 DateTime?
  loggedByUserId             String?
  loggedByUser               User?          @relation("MachineLogUser", fields: [loggedByUserId], references: [id])
  loggedByRequesterName      String?
  acknowledgement             Acknowledgement?
  attachments                Attachment[]
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  @@index([machineId])
  @@index([ticketId])
  @@index([serviceReportId])
  @@index([activityType])
  @@index([workDate])
  @@index([title])
  @@index([notifyCustomer])
  @@index([machineId, workDate], map: "MachineLog_machineId_workDate_idx")
  @@index([machineId, activityType, workDate], map: "MachineLog_machineId_activityType_workDate_idx")
  @@index([ticketId, workDate], map: "MachineLog_ticketId_workDate_idx")
  @@index([serviceReportId, workDate], map: "MachineLog_serviceReportId_workDate_idx")
}

model Task {
  id                 String              @id @default(uuid())
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id])
  machineId          String
  machine            Machine             @relation(fields: [machineId], references: [id])
  ticketId           String?
  ticket             Ticket?             @relation(fields: [ticketId], references: [id])
  title              String
  taskType           TaskType
  description        String?
  scheduledStartAt   DateTime?
  scheduledEndAt     DateTime?
  status             TaskStatus          @default(PENDING)
  priority           TicketPriority      @default(NORMAL)
  notifyRecipientName String?
  notifyRecipientPhone String?
  notifyRecipientEmail String?
  notifiedAt         DateTime?
  createdByUserId    String
  createdByUser      User                @relation("TaskCreatedBy", fields: [createdByUserId], references: [id])
  completedByUserId  String?
  completedByUser    User?               @relation("TaskCompletedBy", fields: [completedByUserId], references: [id])
  completedAt        DateTime?
  internalRemarks    String?
  assignments        TaskAssignment[]
  comments           TaskComment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([customerId])
  @@index([machineId])
  @@index([ticketId])
  @@index([status])
  @@index([scheduledStartAt])
  @@index([notifyRecipientPhone])
  @@index([createdByUserId])
  @@index([completedByUserId])
  @@index([machineId, scheduledStartAt], map: "Task_machineId_scheduledStartAt_idx")
  @@index([ticketId, scheduledStartAt], map: "Task_ticketId_scheduledStartAt_idx")
  @@index([status, scheduledStartAt], map: "Task_status_scheduledStartAt_idx")
}

model TaskAssignment {
  id              String        @id @default(uuid())
  taskId          String
  task            Task          @relation(fields: [taskId], references: [id])
  technicianId    String
  technician      User          @relation("TaskTechnician", fields: [technicianId], references: [id])
  assignedByUserId String?
  assignedByUser  User?         @relation("TaskAssignedBy", fields: [assignedByUserId], references: [id])
  createdAt       DateTime      @default(now())

  @@unique([taskId, technicianId])
  @@index([taskId])
  @@index([technicianId])
  @@index([assignedByUserId])
}

model TaskComment {
  id              String   @id @default(uuid())
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id])
  comment         String
  createdByUserId String
  createdByUser   User     @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([taskId])
  @@index([createdByUserId])
  @@index([taskId, createdAt], map: "TaskComment_taskId_createdAt_idx")
}

model Acknowledgement {
  id                       String                   @id @default(uuid())
  ticketId                 String?
  ticket                   Ticket?                  @relation(fields: [ticketId], references: [id])
  serviceReportId          String?                  @unique
  serviceReport            ServiceReport?           @relation(fields: [serviceReportId], references: [id])
  machineLogId             String?                  @unique
  machineLog               MachineLog?              @relation(fields: [machineLogId], references: [id])
  acknowledgementTokenHash String
  tokenExpiresAt           DateTime
  response                 AcknowledgementResponse?
  requesterName            String?
  requesterPhone           String?
  requesterEmail           String?
  requesterComment         String?
  signatureAttachmentId    String?                  @unique
  signatureAttachment      Attachment?              @relation("AcknowledgementSignature", fields: [signatureAttachmentId], references: [id])
  attachments              Attachment[]             @relation("AcknowledgementAttachments")
  acknowledgedAt           DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([ticketId])
  @@index([serviceReportId])
  @@index([machineLogId])
  @@index([acknowledgementTokenHash])
  @@index([tokenExpiresAt])
  @@index([ticketId, createdAt], map: "Acknowledgement_ticketId_createdAt_idx")
  @@index([response, createdAt], map: "Acknowledgement_response_createdAt_idx")
}

model Attachment {
  id                       String            @id @default(uuid())
  relatedType              AttachmentRelatedType
  ticketId                 String?
  ticket                   Ticket?           @relation(fields: [ticketId], references: [id])
  serviceReportId          String?
  serviceReport            ServiceReport?    @relation(fields: [serviceReportId], references: [id])
  ticketCommentId          String?
  ticketComment            TicketComment?     @relation(fields: [ticketCommentId], references: [id])
  machineLogId             String?
  machineLog               MachineLog?       @relation(fields: [machineLogId], references: [id])
  machineId                String?
  machine                  Machine?          @relation("MachineAttachments", fields: [machineId], references: [id])
  supportCompanyLogoForMachine Machine?      @relation("MachineSupportCompanyLogo")
  acknowledgementId        String?
  acknowledgement          Acknowledgement?   @relation("AcknowledgementAttachments", fields: [acknowledgementId], references: [id])
  signatureFor             Acknowledgement?   @relation("AcknowledgementSignature")
  uploadedByUserId         String?
  uploadedByUser           User?             @relation(fields: [uploadedByUserId], references: [id])
  uploadedByRequesterName  String?
  originalFileName         String
  contentType              String
  fileSizeBytes            Int
  storageBucket            String
  storageKey               String
  checksum                 String?
  createdAt                DateTime          @default(now())

  @@index([ticketId])
  @@index([ticketCommentId])
  @@index([serviceReportId])
  @@index([machineLogId])
  @@index([machineId])
  @@index([acknowledgementId])
  @@index([uploadedByUserId])
  @@index([ticketId, createdAt], map: "Attachment_ticketId_createdAt_idx")
  @@index([ticketCommentId, createdAt], map: "Attachment_ticketCommentId_createdAt_idx")
  @@index([serviceReportId, createdAt], map: "Attachment_serviceReportId_createdAt_idx")
  @@index([machineLogId, createdAt], map: "Attachment_machineLogId_createdAt_idx")
  @@index([machineId, relatedType, createdAt], map: "Attachment_machineId_relatedType_createdAt_idx")
}

model ServiceReminderLog {
  id          String              @id @default(uuid())
  machineId   String
  machine     Machine             @relation(fields: [machineId], references: [id])
  reminderType ReminderType
  dueDate     DateTime
  sentToName  String?
  sentToEmail String?
  sentToPhone String?
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  sentAt      DateTime?
  errorMessage String?
  createdAt   DateTime            @default(now())

  @@index([machineId])
  @@index([dueDate])
  @@index([status])
  @@index([machineId, dueDate], map: "ServiceReminderLog_machineId_dueDate_idx")
  @@index([status, dueDate], map: "ServiceReminderLog_status_dueDate_idx")
}

model AuditLog {
  id                 String   @id @default(uuid())
  actorUserId        String?
  actorUser          User?    @relation(fields: [actorUserId], references: [id])
  actorRequesterName String?
  action             String
  entityType         String
  entityId           String
  beforeData         Json?
  afterData          Json?
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([actorUserId, createdAt], map: "AuditLog_actorUserId_createdAt_idx")
  @@index([entityType, createdAt], map: "AuditLog_entityType_createdAt_idx")
  @@index([action, createdAt], map: "AuditLog_action_createdAt_idx")
}

model NotificationLog {
  id                String             @id @default(uuid())
  relatedType       String?
  relatedId         String?
  channel           NotificationChannel
  recipientName     String?
  recipientEmail    String?
  recipientPhone    String?
  subject           String?
  messageSummary    String?
  status            NotificationStatus @default(PENDING)
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime           @default(now())

  @@index([relatedType, relatedId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt], map: "NotificationLog_status_createdAt_idx")
  @@index([channel, status, createdAt], map: "NotificationLog_channel_status_createdAt_idx")
  @@index([relatedType, relatedId, createdAt], map: "NotificationLog_relatedType_relatedId_createdAt_idx")
}

model WhatsAppWebhookEvent {
  id                String   @id @default(uuid())
  provider          String   @default("meta")
  eventType         String
  providerMessageId String?
  senderPhone       String?
  status            String?
  payload           Json
  receivedAt        DateTime @default(now())

  @@index([provider, receivedAt], map: "WhatsAppWebhookEvent_provider_receivedAt_idx")
  @@index([eventType, receivedAt], map: "WhatsAppWebhookEvent_eventType_receivedAt_idx")
  @@index([providerMessageId], map: "WhatsAppWebhookEvent_providerMessageId_idx")
}

model SystemSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
